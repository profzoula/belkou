{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "belkou",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "vars": {
    "SITE_URL": "https://belkou.online",
    "EMAIL_FROM": "BelKou <noreply@belkou.fr>"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "belkou-db",
      "database_id": "local-dev-belkou-db"
    }
  ]
}
